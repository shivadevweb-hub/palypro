{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile and subscription settings",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "currentPlanId": { "type": "string" },
        "selectedToyIds": { "type": "array", "items": { "type": "string" } },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name", "isAdmin"]
    },
    "Toy": {
      "title": "Toy Asset",
      "description": "Premium toy available for lease",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "ageRange": { "type": "string" },
        "image": { "type": "string" },
        "points": { "type": "integer" },
        "available": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "points", "image"]
    },
    "Order": {
      "title": "Lease Order",
      "description": "A toy lease order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "toyIds": { "type": "array", "items": { "type": "string" } },
        "toyNames": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "delivered", "swapped"] },
        "shippingAddress": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "deliveryDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "toyIds", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/toys/{toyId}": {
      "schema": "Toy",
      "description": "Toy catalog"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Lease orders"
    }
  }
}
