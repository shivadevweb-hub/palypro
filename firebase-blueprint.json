{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with plan and selected toys",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "currentPlanId": { "type": "string" },
        "selectedToyIds": { "type": "array", "items": { "type": "string" } },
        "address": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["email", "name", "isAdmin", "selectedToyIds"]
    },
    "Order": {
      "title": "Rental Order",
      "description": "Information about a toy rental/swap cycle",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "toyIds": { "type": "array", "items": { "type": "string" } },
        "toyNames": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "delivered", "swapped"] },
        "shippingAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "deliveryDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "toyIds", "status", "shippingAddress", "createdAt"]
    },
    "Toy": {
      "title": "Toy Document",
      "description": "Toy details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "image": { "type": "string" },
        "ageRange": { "type": "string" },
        "category": { "type": "string" },
        "shortDescription": { "type": "string" },
        "fullDescription": { "type": "string" },
        "brand": { "type": "string" },
        "available": { "type": "boolean" }
      },
      "required": ["name", "image", "ageRange", "category", "shortDescription", "fullDescription", "brand", "available"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Private user profiles"
    },
    "toys/{toyId}": {
      "schema": "Toy",
      "description": "Public toy collection"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Rental and delivery orders"
    },
    "admins/{userId}": {
      "schema": { "type": "object", "properties": { "email": { "type": "string" } } },
      "description": "Admin list"
    }
  }
}
