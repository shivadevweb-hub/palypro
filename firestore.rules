rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'adminplaypro@gmail.com' ||
        request.auth.token.email.lower() == 'admin@playpro.com' ||
        request.auth.token.email.lower() == 'shivadevweb@gmail.com'
      );
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['email', 'name', 'isAdmin']) &&
        request.resource.data.isAdmin == false; // Users cannot self-promote to admin
      allow update: if (isOwner(userId) || isAdmin()) && (
        // Action: Update profile details by owner
        (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'address', 'phone', 'selectedToyIds', 'currentPlanId', 'updatedAt', 'photoURL'])) ||
        // Action: Update sensitive fields by admin
        (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAdmin', 'updatedAt']))
      );
    }
    
    // Toys Collection
    match /toys/{toyId} {
      allow list: if true; // Publicly viewable catalog
      allow get: if true;
      allow write: if isAdmin();
    }
    
    // Orders
    match /orders/{orderId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
